# ============================================================
# AI 教學計畫系統 — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================================

# ===== 資料庫 (必填) =====
# MongoDB 連線字串。本地開發用 localhost，Railway 請使用 MongoDB Atlas 連線字串
MONGODB_URI=mongodb://localhost:27017
# 資料庫名稱
MONGODB_DB_NAME=courses_system

# ===== JWT 認證 (必填) =====
# 用於簽發 JWT Token 的密鑰，請使用至少 32 字元的隨機字串
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
# JWT 演算法，預設 HS256 即可
JWT_ALGORITHM=HS256
# Token 過期時間（分鐘），預設 30 分鐘
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== 去識別化 (必填) =====
# 用於 SHA256 雜湊 LINE User ID 的鹽值，請使用至少 32 字元的隨機字串
# 一旦設定後請勿更改，否則已有的 pseudonym 將無法對應
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(32))"
PSEUDONYM_SALT=f57feff87bc3ef4d91afa307bf725c7bb1178dece34bcd7adef02e49d32c8881

# ===== LINE Bot (選填，不使用 LINE 功能可留空) =====
# 從 LINE Developers Console 取得
# https://developers.line.biz/
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ===== Google Gemini AI (選填，不使用 AI 功能可留空) =====
# 從 Google AI Studio 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Gemini 模型名稱，預設 gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# ===== API 伺服器 (選填，有預設值) =====
# 監聽位址，預設 0.0.0.0
API_HOST=0.0.0.0
# 監聽埠號，預設 8000
API_PORT=8000

# ===== CORS (選填，有預設值) =====
# 允許的前端來源，多個以逗號分隔
# 本地開發: http://localhost:3000,http://localhost:5173
# Railway 部署: 填入前端服務的 Railway URL，例如 https://courses-frontend-production.up.railway.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
