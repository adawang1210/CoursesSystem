FROM node:20-slim

WORKDIR /app

# 設定後端 API URL（Railway 部署用）
ENV NEXT_PUBLIC_API_URL=https://coursessystem-production.up.railway.app

# 複製 package 檔案並安裝所有依賴（含 devDependencies，build 需要）
COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps

# 複製其餘原始碼並建置
COPY . .
RUN npm run build

ENV NODE_ENV=production

EXPOSE 3000

CMD ["npm", "start"]
